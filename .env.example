# Neon Postgres connection string.
# In production, set this in Vercel Project Settings or via the Neon Marketplace integration.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Optional: comma-separated extra browser origins for local/custom-domain CORS.
# Same-domain Vercel deployments do not need this.
# ALLOWED_ORIGINS="https://your-domain.example"

# Optional: local-only fallback when DATABASE_URL is not available.
# Do not enable this in production, because data will be lost on server restart.
# ALLOW_MEMORY_STORAGE=1
